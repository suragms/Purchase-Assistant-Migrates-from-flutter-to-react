# =============================================================================
# Harisree / HEXA Purchase Assistant — Environment template
# Copy this file to backend/.env (and admin_web/.env.local for Vite). Never commit real secrets.
#
# Why keys in this file were cleared once: GitHub "push protection" blocks commits that contain
# strings that look like live API keys — even in .env.example. Real values belong only in backend/.env
# on your machine (that file is gitignored). Recreate keys from each provider's dashboard if needed.
#
# If keys were ever in git or chat: revoke them in the provider console and create new keys.
#
# Quick guide — set when:
#   Core app + login   → App + Database + Redis + JWT + CORS
#   Production auth    → Strong JWT secrets; DEV_RETURN_OTP=false (legacy OTP helpers if re-enabled later)
#   In-app assistant   → ENABLE_AI + AI_PROVIDER + keys (POST /v1/businesses/{id}/ai/chat)
#   AI parse (OpenAI)  → OPENAI_* + ENABLE_AI=true
#   AI alt (Gemini)    → GOOGLE_AI_API_KEY (when backend supports it — not all routes wired yet)
#   AI alt (Groq)      → GROQ_API_KEY (when backend supports it)
#   OCR / Voice        → OCR_* / STT_* + S3_* for uploads + ENABLE_OCR / ENABLE_VOICE
#   Billing            → RAZORPAY_* + PLAN_*_PRICE_INR
#   Observability      → SENTRY_DSN, LOG_LEVEL, HTTP_SLOW_REQUEST_WARNING_MS, Sentry; METRICS_TOKEN reserved
#   Super admin        → SUPERADMIN_BOOTSTRAP_EMAIL (or legacy SUPERADMIN_BOOTSTRAP_PHONE); admin UI: VITE_ADMIN_BEARER (JWT) or ADMIN_API_TOKEN (static Bearer)
# =============================================================================

# --- App ---
APP_ENV=development
APP_NAME=hexa-purchase-assistant
APP_URL=http://localhost:8000
ADMIN_URL=http://localhost:5173
# Admin SPA (Vite) — set in admin_web/.env.local, not always in this file:
#   VITE_API_BASE_URL=http://localhost:8000
#   VITE_ADMIN_BEARER=<super-admin JWT>
# Must include every browser origin that calls the API (Flutter web uses http://127.0.0.1:8080 etc.).
# In development (APP_ENV=development) the API also allows any http(s) localhost / 127.0.0.1 / [::1] port via regex — see backend app/main.py.
# If sign-in fails only in the browser, start uvicorn first; mismatch of localhost vs 127.0.0.1 in API_BASE_URL can confuse testers.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080

# Comma-separated hosts for TrustedHostMiddleware (production behind reverse proxy). Empty = disabled.
TRUSTED_HOSTS=

# --- Database & cache ---
# Postgres (production / team): postgresql+asyncpg://user:password@localhost:5432/hexa
# Quick local dev (no Postgres): sqlite+aiosqlite:///./hexa_dev.db
# Login/sign-up need a working DB. If login returns 500, use SQLite line below and restart the API.
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/hexa
# DATABASE_URL=sqlite+aiosqlite:///./hexa_dev.db
#
# Production / Supabase: NEVER set the next var on the deployed host. If HEXA_USE_SQLITE=1, the API
# ignores your Postgres URL and uses a fresh empty SQLite file on the server (dashboards show zeros).
# HEXA_USE_SQLITE=1
HEXA_USE_SQLITE=
# Render / cloud: if direct db.<project>.supabase.co:5432 fails with "Network is unreachable" (or "Not IPv4
# compatible" in dashboard), paste the Session or Transaction pooler URI from Supabase → Connect instead.
# Transaction pooler often uses port 6543 and *.pooler.supabase.com — see docs/supabase-mcp-and-database.md
# for the hosted project's host/ref. When set, the API uses pooler env instead of plain DATABASE_URL.
# If the DB password contains @ or other reserved URI characters, do NOT put the password in the URL — use USER@HOST only and set DATABASE_POOLER_PASSWORD below.
# DATABASE_POOLER_URL=postgresql+asyncpg://postgres.PROJECT_REF@aws-0-REGION.pooler.supabase.com:6543/postgres
# DATABASE_POOLER_PASSWORD=your-actual-password
DATABASE_POOLER_URL=
DATABASE_POOLER_PASSWORD=
# If Postgres TLS fails with CERTIFICATE_VERIFY_FAILED (some antivirus/proxies), set true locally only — never in production.
DATABASE_SSL_INSECURE=false
# If Postgres TLS fails with SSLCertVerificationError on Render+Supabase pooler, try true (still encrypted; skips cert chain verify).
DATABASE_SSL_SKIP_VERIFY=false
REDIS_URL=redis://localhost:6379/0
# Local dev without Redis:
# REDIS_URL=
# Render without Redis add-on (OTP falls back to in-memory on a single instance):
# REDIS_URL=

# Optional: absolute path to folder with the three seed JSONs (default: <repo>/data/files, then backend/scripts/data).
# Required for production if the process cwd is not the repo (e.g. some PaaS): bootstrap-workspace and seed scripts
# need categories_seed.json, products_by_category_seed.json, suppliers_gst_seed.json on disk.
# SEED_DATA_DIR=/path/to/some/folder

# --- Auth / JWT ---
JWT_SECRET=change-me-min-48-chars
JWT_REFRESH_SECRET=change-me-min-48-chars
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30
# Same value(s) as Flutter `--dart-define=GOOGLE_OAUTH_CLIENT_ID` (usually one Web client ID).
GOOGLE_OAUTH_CLIENT_IDS=

DEV_RETURN_OTP=true
DEV_OTP_CODE=000000

# OTP (e.g. Twilio Verify, MSG91, AWS SNS — set provider-specific vars)
OTP_PROVIDER=twilio
OTP_API_KEY=
OTP_SENDER_ID=HEXA
OTP_REQUESTS_PER_MINUTE_PER_IP=10
OTP_REQUESTS_PER_10_MINUTES_PER_PHONE=3
OTP_FAILED_ATTEMPTS_LOCKOUT_THRESHOLD=5
OTP_FAILED_ATTEMPTS_LOCKOUT_MINUTES=30

# --- Render / production checklist (AI assistant) ---
# 1) Set APP_URL / public API base to your Render URL.
# 2) LLM (optional but recommended): set exactly ONE provider + key — stub means no external LLM calls.
#    AI_PROVIDER=openai   + OPENAI_API_KEY
#    AI_PROVIDER=groq     + GROQ_API_KEY
#    AI_PROVIDER=gemini   + GOOGLE_AI_API_KEY
# 3) Flutter app calls POST /v1/businesses/{business_id}/ai/chat for the in-app assistant.

# --- AI — provider for POST /v1/businesses/{id}/ai/intent ---
# stub = regex-only (no external API). openai | groq | gemini = LLM JSON (keys from env or DB platform_integration).
# Use groq for real assistant: AI_PROVIDER=groq + GROQ_API_KEY (otherwise stub is safe for dev)
AI_PROVIDER=stub
# Optional: legacy env flags (still parsed if present; unused when WhatsApp HTTP routes are not deployed).
WHATSAPP_LLM_REPLY=false
WHATSAPP_LLM_AGENT=false

# --- AI — OpenAI (paste key only in backend/.env) ---
# Dashboard: https://platform.openai.com/api-keys — keys usually start with sk-proj- or sk-
OPENAI_API_KEY=
OPENAI_MODEL_PARSE=gpt-4.1-mini
OPENAI_MODEL_SUMMARY=gpt-4.1-mini

# --- AI — Google Gemini (AI_PROVIDER=gemini) ---
# Google AI Studio / Cloud console — key type often starts with AIza (paste only in backend/.env)
GOOGLE_AI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- AI — Groq (AI_PROVIDER=groq) ---
# https://console.groq.com/keys — keys usually start with gsk_ (paste only in backend/.env)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Runtime overrides (no redeploy) ---
# Super-admin can PUT /v1/admin/platform-integration to store the same keys in the DB.
# Empty string on PUT clears the DB value for that field (falls back to env vars above).

# --- OCR ---
OCR_PROVIDER=google_vision
OCR_API_KEY=

# --- Speech-to-text ---
STT_PROVIDER=openai_whisper
STT_API_KEY=

# --- Object storage (receipts / audio) ---
S3_BUCKET=
S3_REGION=ap-south-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# --- Billing (India example: Razorpay) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# When true, WhatsApp/AI require paid add-ons on BusinessSubscription (grandfather: no row = allowed).
BILLING_ENFORCE=false
# Bundle pricing in paise: infra base + optional WhatsApp+AI combo (see billing/quote).
BILLING_CLOUD_INFRA_PAISE=230000
BILLING_WHATSAPP_AI_ADDON_PAISE=250000
PLAN_BASIC_PRICE_INR=49900
PLAN_PRO_PRICE_INR=99900
PLAN_PREMIUM_PRICE_INR=199900

# --- Observability ---
SENTRY_DSN=
LOG_LEVEL=INFO
# Log WARNING when any HTTP request exceeds this many ms (middleware: SLOW_HTTP …). 0 disables.
HTTP_SLOW_REQUEST_WARNING_MS=500
# Echo X-Request-Id and X-Process-Time-Ms on responses; Flutter sends X-Request-Id per request for log correlation.
HTTP_PROPAGATE_REQUEST_ID=true
# If true, emit structured HTTP_JSON for every route (not only /v1/businesses/*). Render: set true briefly when debugging traffic (noisy at scale).
HTTP_ACCESS_LOG_ALL=false
# SQLAlchemy: log slow statements on sync diagnostics path (async uses command timeout separately).
DATABASE_SLOW_QUERY_LOG_MS=200
# Cap curated heavy GET reads (snapshot, home-overview, etc.); 0 disables asyncio budget.
API_READ_BUDGET_SECONDS=4
METRICS_TOKEN=

# --- Feature flags (defaults; DB overrides per tenant) ---
ENABLE_AI=true
ENABLE_OCR=false
ENABLE_VOICE=false
ENABLE_REALTIME=true

# --- Admin API (dashboard + automation) ---
# Optional. If set, `Authorization: Bearer <token>` can call /v1/admin/* without a user JWT (machine auth).
# Use a long random string; keep secret. Super-admin JWT still works when this is unset.
ADMIN_API_TOKEN=

# --- Bootstrap super admin (one-time setup) ---
# First registered user with this email becomes super admin (recommended).
SUPERADMIN_BOOTSTRAP_EMAIL=
# Legacy (phone-based bootstrap); prefer SUPERADMIN_BOOTSTRAP_EMAIL.
SUPERADMIN_BOOTSTRAP_PHONE=+919999999999

# =============================================================================
# WhatsApp — outbound (Cloud API) & scheduled purchase reports
# =============================================================================
# Used by internal cron POST → send due WhatsApp report summaries (see whatsapp_reports router).
# Leave blank if you only use in-app features (no server-side WhatsApp sends).
# WHATSAPP_CLOUD_ACCESS_TOKEN=
# WHATSAPP_CLOUD_PHONE_NUMBER_ID=
# Long random secret — Render/other cron must send the same value when calling the internal endpoint.
# WHATSAPP_REPORTS_CRON_SECRET=
#
# Optional BSP / Authkey (see backend app/config.py field names): DIALOG360_* , AUTHKEY_* ,
# WHATSAPP_ASSISTANT_E164 , AUTHKEY_WEBHOOK_SECRET . Webhook rate limits: WEBHOOK_MAX_PER_MINUTE ,
# WEBHOOK_MAX_PER_HOUR (in-process; tune if multi-instance).
