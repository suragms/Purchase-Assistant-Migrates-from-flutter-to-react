{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install --ignore-scripts --no-audit --no-fund",
  "buildCommand": "bash scripts/vercel-flutter-build.sh",
  "outputDirectory": "flutter_app/build/web",
  "build": {
    "env": {
      "FLUTTER_VERSION": "3.41.6",
      "BUILD_MAX_WORKERS_PER_TASK": "1",
      "DART_VM_OPTIONS": "--max-old-space-size=3072",
      "API_BASE_URL": "https://my-purchases-api.onrender.com"
    }
  },
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/main.dart.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/flutter.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/flutter_bootstrap.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
