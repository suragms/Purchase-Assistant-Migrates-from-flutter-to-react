{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=hexa;Username=hexa;Password=hexa",
    "Redis": "redis://localhost:6379/0"
  },
  "Jwt": {
    "Secret": "change-me-min-32-chars-dev-only-secret",
    "RefreshSecret": "change-me-min-32-chars-refresh-dev",
    "AccessTtlMinutes": 15,
    "RefreshTtlDays": 30
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "Application": "PurchaseAssistant.Api",
      "Environment": "Development"
    }
  },
  "AllowedHosts": "*",
  "CorsOrigins": "http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:5175,http://127.0.0.1:5175,http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080",
  "AppSettings": {
    "AppEnv": "development",
    "AppName": "hexa-purchase-assistant",
    "AppUrl": "http://localhost:5131",
    "AdminUrl": "http://localhost:5173",
    "LogLevel": "INFO",
    "AllowPublicRegistration": false,
    "SuperadminBootstrapEmail": null,
    "GoogleOAuthClientIds": "",
    "OpenAiApiKey": null,
    "AiProvider": "stub",
    "OcrProvider": "google_vision",
    "EnableAi": true,
    "EnableOcr": false,
    "EnableRealtime": true,
    "EnableVision": true,
    "EnableAiExtraction": true
  },
  "Cache": {
    "TtlStockList": 30,
    "TtlHomeDashboard": 60,
    "TtlCatalogItems": 120,
    "TtlPurchaseList": 30,
    "TtlStockShell": 30
  }
}
